{
  "name": "localterm",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/fix-node-pty.mjs",
    "build": "turbo run build",
    "benchmark:output": "node scripts/benchmark-output-pipeline.mjs",
    "dev": "turbo run dev --parallel",
    "start": "node packages/cli/bin/localterm.mjs restart",
    "start:dev": "node packages/cli/bin/localterm.mjs restart",
    "stop": "node packages/cli/bin/localterm.mjs stop",
    "dev:all": "LOCALTERM_DEV=1 node packages/cli/bin/localterm.mjs restart --foreground --no-open & sleep 3 && (open http://localhost:5174 &) 2>/dev/null; turbo run dev --parallel && kill %1",
    "cli": "node packages/cli/bin/localterm.mjs",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration --concurrency=2",
    "test:e2e": "turbo run test:e2e --concurrency=2",
    "typecheck": "turbo run typecheck",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "lint:dead": "knip",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.5.0",
    "@voidzero-dev/vite-plus-core": "^0.1.12",
    "knip": "^6.26.0",
    "turbo": "^2.9.3",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.12"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "node-pty",
      "sharp",
      "spawn-sync",
      "unrs-resolver"
    ],
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core"
    },
    "patchedDependencies": {
      "@xterm/addon-webgl@0.20.0-beta.286": "patches/@xterm__addon-webgl@0.20.0-beta.286.patch"
    }
  }
}
