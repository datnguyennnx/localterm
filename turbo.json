{
  "$schema": "https://v2-10-5.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "@datnguyennnx/localterm#build": {
      "dependsOn": [
        "@datnguyennnx/localterm-server#build",
        "@datnguyennnx/localterm-terminal#build"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"]
    },
    "test:integration": {
      "dependsOn": ["build"],
      "inputs": ["src/**", "tests/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tests/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "format": {},
    "check": {}
  }
}
